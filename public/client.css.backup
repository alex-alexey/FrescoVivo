* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --primary-color: #0077BE;
    --secondary-color: #00A8E8;
    --accent-color: #FF6B35;
    --dark-blue: #003459;
    --light-blue: #E8F4F8;
    --gradient-1: linear-gradient(135deg, #0077BE 0%, #00A8E8 100%);
    --gradient-2: linear-gradient(135deg, #003459 0%, #0077BE 100%);
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background: #ffffff;
    min-height: 100vh;
    overflow-x: hidden;
}

.container {
    max-width: 1400px;
    margin: 0 auto;
}

/* Navbar */
.navbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 50px;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
    z-index: 1000;
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.5em;
    font-weight: bold;
    color: var(--dark-blue);
}

.logo-icon {
    font-size: 1.8em;
}

.nav-links {
    display: flex;
    gap: 30px;
}

.nav-links a {
    text-decoration: none;
    color: var(--dark-blue);
    font-weight: 500;
    transition: color 0.3s;
}

.nav-links a:hover {
    color: var(--primary-color);
}

/* Hero Section */
.hero {
    background: var(--gradient-1);
    padding: 120px 50px 80px;
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
}

.hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 400"><path fill="rgba(255,255,255,0.05)" d="M0,100 Q300,50 600,100 T1200,100 L1200,0 L0,0 Z"/></svg>');
    background-size: cover;
    opacity: 0.3;
}

.hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
}

.hero-text {
    color: white;
}

.hero-status-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 20px;
    border-radius: 50px;
    font-weight: 600;
    font-size: 0.95em;
    margin-bottom: 20px;
    backdrop-filter: blur(10px);
    transition: all 0.3s;
}

.hero-status-badge.online {
    background: rgba(72, 187, 120, 0.3);
    border: 2px solid #48bb78;
    color: white;
}

.hero-status-badge.offline {
    background: rgba(203, 213, 224, 0.3);
    border: 2px solid #cbd5e0;
    color: white;
}

.hero-status-badge .status-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: currentColor;
}

.hero-status-badge.online .status-dot {
    animation: pulse 2s infinite;
}

.hero-title {
    font-size: 4em;
    font-weight: 800;
    margin-bottom: 20px;
    line-height: 1.1;
    display: flex;
    flex-direction: column;
}

.title-line-1 {
    color: white;
}

.title-line-2 {
    color: var(--accent-color);
}

.hero-subtitle {
    font-size: 1.5em;
    margin-bottom: 15px;
    font-weight: 600;
}

.hero-description {
    font-size: 1.1em;
    line-height: 1.6;
    margin-bottom: 30px;
    opacity: 0.95;
}

.hero-cta {
    display: flex;
    gap: 15px;
    margin-bottom: 50px;
}

.btn-hero {
    background: var(--accent-color);
    color: white;
    padding: 15px 35px;
    border: none;
    border-radius: 50px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
    box-shadow: 0 5px 20px rgba(255, 107, 53, 0.4);
}

.btn-hero:hover:not(:disabled) {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(255, 107, 53, 0.6);
}

.btn-hero:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-secondary-outline {
    background: transparent;
    color: white;
    padding: 15px 35px;
    border: 2px solid white;
    border-radius: 50px;
    font-size: 1.1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
}

.btn-secondary-outline:hover {
    background: white;
    color: var(--primary-color);
}

.hero-stats {
    display: flex;
    gap: 40px;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-number {
    font-size: 2.5em;
    font-weight: 800;
    color: var(--accent-color);
}

.stat-label {
    font-size: 0.9em;
    opacity: 0.9;
}

.hero-visual {
    display: flex;
    flex-direction: column;
    gap: 20px;
    justify-content: center;
}

.visual-card {
    background: white;
    padding: 30px;
    border-radius: 20px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    animation: floating 3s ease-in-out infinite;
}

.visual-card.floating-delay {
    animation-delay: 0.5s;
}

.visual-card.floating-delay-2 {
    animation-delay: 1s;
}

@keyframes floating {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

.visual-icon {
    font-size: 3em;
    margin-bottom: 15px;
}

.visual-card h3 {
    color: var(--dark-blue);
    font-size: 1.3em;
    margin-bottom: 10px;
}

.visual-card p {
    color: #666;
    font-size: 0.95em;
}

.wave-divider {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    overflow: hidden;
    line-height: 0;
}

.wave-divider svg {
    position: relative;
    display: block;
    width: calc(100% + 1.3px);
    height: 80px;
}

/* How It Works Section */
.how-it-works {
    padding: 80px 50px;
    background: white;
}

.section-title {
    text-align: center;
    font-size: 2.5em;
    color: var(--dark-blue);
    margin-bottom: 50px;
    font-weight: 700;
}

.steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1400px;
    margin: 0 auto;
}

.step-card {
    text-align: center;
    padding: 30px;
    background: var(--light-blue);
    border-radius: 20px;
    transition: all 0.3s;
    position: relative;
}

.step-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 10px 30px rgba(0, 119, 190, 0.2);
}

.step-number {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 40px;
    background: var(--accent-color);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.2em;
}

.step-icon {
    font-size: 3em;
    margin: 20px 0;
}

.step-card h3 {
    color: var(--dark-blue);
    font-size: 1.2em;
    margin-bottom: 15px;
}

.step-card p {
    color: #666;
    line-height: 1.6;
}

/* Products Section */
.products-preview {
    padding: 80px 50px;
    background: #f8f9fa;
}

.products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
    max-width: 1400px;
    margin: 0 auto;
}

.product-showcase {
    background: white;
    padding: 40px;
    border-radius: 20px;
    text-align: center;
    transition: all 0.3s;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
}

.product-showcase:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
}

.product-image {
    font-size: 4em;
    margin-bottom: 20px;
}

.product-showcase h3 {
    color: var(--dark-blue);
    font-size: 1.3em;
    margin-bottom: 10px;
}

.product-showcase p {
    color: #666;
}

/* CTA Section */
.cta-section {
    padding: 80px 50px;
    background: var(--gradient-2);
    text-align: center;
    color: white;
}

.cta-content {
    max-width: 700px;
    margin: 0 auto;
}

.status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.2);
    padding: 12px 25px;
    border-radius: 50px;
    margin-bottom: 30px;
    backdrop-filter: blur(10px);
}

.status-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    animation: pulse 2s infinite;
}

.status-dot.online {
    background: #48bb78;
    box-shadow: 0 0 10px #48bb78;
}

.status-dot.offline {
    background: #cbd5e0;
    animation: none;
}

@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
}

.status-text {
    font-weight: 600;
}

.cta-content h2 {
    font-size: 2.5em;
    margin-bottom: 15px;
}

.cta-content p {
    font-size: 1.2em;
    margin-bottom: 30px;
    opacity: 0.9;
}

/* Footer */
.footer {
    background: var(--dark-blue);
    color: white;
    text-align: center;
    padding: 30px;
}

/* Modal */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.7);
    align-items: center;
    justify-content: center;
    z-index: 2000;
    backdrop-filter: blur(5px);
}

.modal-content {
    background: white;
    padding: 40px;
    border-radius: 20px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    position: relative;
    animation: modalSlideIn 0.3s ease;
}

@keyframes modalSlideIn {
    from {
        opacity: 0;
        transform: translateY(-50px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.modal-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: none;
    border: none;
    font-size: 2em;
    cursor: pointer;
    color: #999;
    transition: color 0.3s;
}

.modal-close:hover {
    color: var(--accent-color);
}

.modal-content h2 {
    color: var(--dark-blue);
    margin-bottom: 15px;
}

.modal-content p {
    color: #666;
    margin-bottom: 20px;
}

/* Pantalla de cola */
.queue-info, .confirmation-card {
    background: white;
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
}

.queue-info h2, .confirmation-card h2 {
    color: var(--primary-color);
    margin-bottom: 20px;
}

#queue-screen {
    padding: 20px;
    min-height: 100vh;
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
}

input[type="text"], input[type="number"] {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 16px;
    transition: border-color 0.3s;
}

input:focus {
    outline: none;
    border-color: var(--primary-color);
}

.btn-primary, .btn-secondary, .btn-danger, .btn-control {
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.3s;
    margin: 5px;
}

.btn-primary {
    background: var(--primary-color);
    color: white;
    width: 100%;
}

.btn-primary:hover {
    background: var(--dark-blue);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0, 119, 190, 0.4);
}

.btn-secondary {
    background: #48bb78;
    color: white;
}

.btn-secondary:hover {
    background: #38a169;
}

.btn-danger {
    background: #f56565;
    color: white;
}

.btn-danger:hover {
    background: #e53e3e;
}

.btn-control {
    background: #4a5568;
    color: white;
}

.btn-control:hover {
    background: #2d3748;
}

/* Pantalla de cola */
.position-display {
    margin: 30px 0;
}

.position-number {
    font-size: 5em;
    color: var(--primary-color);
    font-weight: bold;
    margin: 20px 0;
}

.queue-text {
    font-size: 1.2em;
    color: #666;
    margin: 15px 0;
}

.waiting-text {
    color: #999;
    margin-top: 20px;
}

.loader {
    border: 4px solid #f3f3f3;
    border-top: 4px solid var(--primary-color);
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
    margin: 20px auto;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Pantalla de videollamada */
#call-screen {
    background: #1a1a1a;
    padding: 20px;
    min-height: 100vh;
}

.call-header {
    text-align: center;
    color: white;
    margin-bottom: 30px;
    padding: 20px;
    background: rgba(0, 119, 190, 0.2);
    border-radius: 15px;
}

.call-header h2 {
    font-size: 2em;
    margin-bottom: 10px;
}

.call-info {
    font-size: 1.1em;
    opacity: 0.9;
}

.video-grid {
    max-width: 1400px;
    margin: 0 auto 30px;
}

.main-video-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.vendor-main-video {
    position: relative;
    background: #000;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.vendor-main-video video {
    width: 100%;
    height: 600px;
    object-fit: cover;
}

.product-cameras-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.product-video-small {
    position: relative;
    background: #000;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0, 0, 0, 0.4);
}

.product-video-small video {
    width: 100%;
    height: 300px;
    object-fit: cover;
}

.video-label {
    position: absolute;
    bottom: 15px;
    left: 15px;
    background: rgba(0, 119, 190, 0.9);
    color: white;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
}

.call-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    padding: 20px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50px;
    max-width: 600px;
    margin: 0 auto;
    backdrop-filter: blur(10px);
}

.call-controls .btn-control,
.call-controls .btn-danger {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 40px;
    border-radius: 15px;
    font-size: 14px;
    font-weight: 600;
    min-width: 120px;
}

.call-controls .btn-control span:first-child,
.call-controls .btn-danger span:first-child {
    font-size: 2em;
}

.call-controls .btn-control {
    background: var(--primary-color);
}

.call-controls .btn-control:hover {
    background: var(--dark-blue);
}

.call-controls .btn-danger {
    background: #e53e3e;
}

.call-controls .btn-danger:hover {
    background: #c53030;
}

/* Pantalla de confirmación */
#order-summary {
    background: #f7fafc;
    padding: 20px;
    border-radius: 10px;
    margin: 20px 0;
    text-align: left;
}

#order-summary p {
    margin: 10px 0;
    color: #666;
}

/* Responsive */
@media (max-width: 1024px) {
    .hero-content {
        grid-template-columns: 1fr;
    }
    
    .steps-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .products-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .product-cameras-row {
        grid-template-columns: 1fr;
    }
    
    .vendor-main-video video {
        height: 400px;
    }
    
    .product-video-small video {
        height: 250px;
    }
}

@media (max-width: 768px) {
    .navbar {
        padding: 15px 20px;
    }
    
    .nav-links {
        display: none;
    }
    
    .hero {
        padding: 100px 20px 60px;
    }
    
    .hero-title {
        font-size: 2.5em;
    }
    
    .hero-cta {
        flex-direction: column;
    }
    
    .hero-stats {
        flex-direction: column;
        gap: 20px;
    }
    
    .steps-grid {
        grid-template-columns: 1fr;
    }
    
    .products-grid {
        grid-template-columns: 1fr;
    }
    
    .how-it-works, .products-preview, .cta-section {
        padding: 60px 20px;
    }
    
    .section-title {
        font-size: 2em;
    }
    
    .vendor-main-video video {
        height: 300px;
    }
    
    .product-video-small video {
        height: 200px;
    }
    
    .call-controls {
        flex-direction: column;
        border-radius: 20px;
    }
    
    .call-controls .btn-control,
    .call-controls .btn-danger {
        width: 100%;
    }
}

input[type="text"], input[type="number"] {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    font-size: 16px;
    transition: border-color 0.3s;
}

input:focus {
    outline: none;
    border-color: #667eea;
}

.btn-primary, .btn-secondary, .btn-danger, .btn-control {
    padding: 12px 30px;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    cursor: pointer;
    transition: all 0.3s;
    margin: 5px;
}

.btn-primary {
    background: #667eea;
    color: white;
    width: 100%;
}

.btn-primary:hover {
    background: #5568d3;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
}

.btn-secondary {
    background: #48bb78;
    color: white;
}

.btn-secondary:hover {
    background: #38a169;
}

.btn-danger {
    background: #f56565;
    color: white;
}

.btn-danger:hover {
    background: #e53e3e;
}

.btn-control {
    background: #4a5568;
    color: white;
}

.btn-control:hover {
    background: #2d3748;
}

/* Pantalla de cola */
.position-display {
    margin: 30px 0;
}

.position-number {
    font-size: 5em;
    color: #667eea;
    font-weight: bold;
    margin: 20px 0;
}

.queue-text {
    font-size: 1.2em;
    color: #666;
    margin: 15px 0;
}

.waiting-text {
    color: #999;
    margin-top: 20px;
}

.loader {
    border: 4px solid #f3f3f3;
    border-top: 4px solid #667eea;
    border-radius: 50%;
    width: 50px;
    height: 50px;
    animation: spin 1s linear infinite;
    margin: 20px auto;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

/* Pantalla de videollamada */
#call-screen {
    background: transparent;
}

.video-container {
    display: grid;
    grid-template-columns: 3fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
}

.main-videos {
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.vendor-stream {
    position: relative;
    background: #000;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.3);
}

.vendor-stream video {
    width: 100%;
    height: 400px;
    object-fit: cover;
}

.product-streams {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 15px;
}

.product-video {
    position: relative;
    background: #000;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 3px 15px rgba(0,0,0,0.3);
}

.product-video video {
    width: 100%;
    height: 200px;
    object-fit: cover;
}

.your-video {
    position: relative;
    background: #000;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 5px 20px rgba(0,0,0,0.3);
}

.your-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.vendor-stream label, .product-video label, .your-video label {
    position: absolute;
    bottom: 10px;
    left: 10px;
    background: rgba(0,0,0,0.7);
    color: white;
    padding: 5px 10px;
    border-radius: 5px;
    font-size: 12px;
}

/* Panel de pedido */
.order-panel {
    background: white;
    border-radius: 15px;
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
}

.order-panel h3 {
    color: #667eea;
    margin-bottom: 15px;
}

.order-form {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 20px;
}

.cart {
    border-top: 2px solid #e0e0e0;
    padding-top: 20px;
}

.cart h4 {
    color: #667eea;
    margin-bottom: 10px;
}

#cart-items {
    list-style: none;
    margin-bottom: 15px;
    max-height: 150px;
    overflow-y: auto;
}

#cart-items li {
    padding: 8px;
    background: #f7fafc;
    margin-bottom: 5px;
    border-radius: 5px;
    display: flex;
    justify-content: space-between;
}

.total {
    font-size: 1.5em;
    font-weight: bold;
    color: #667eea;
    text-align: right;
    margin-bottom: 15px;
}

.controls {
    text-align: center;
    background: white;
    padding: 15px;
    border-radius: 15px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
}

/* Pantalla de confirmación */
#order-summary {
    background: #f7fafc;
    padding: 20px;
    border-radius: 10px;
    margin: 20px 0;
    text-align: left;
}

#order-summary p {
    margin: 10px 0;
    color: #666;
}

@media (max-width: 1024px) {
    .video-container {
        grid-template-columns: 1fr;
    }
    
    .product-streams {
        grid-template-columns: repeat(3, 1fr);
    }
    
    .order-form {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 768px) {
    header h1 {
        font-size: 2em;
    }
    
    .product-streams {
        grid-template-columns: 1fr;
    }
}
