# Archivo de variables de entorno
# Copia este archivo como .env y configura tus valores

# ================================
# CONFIGURACIÓN PRINCIPAL
# ================================

# Puerto del servidor
PORT=3000

# Entorno (development, production)
NODE_ENV=development

# ================================
# MONGODB (REQUERIDO)
# ================================
# Conexión a MongoDB Atlas - Base de datos MASTER para multi-tenant
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/pescadolive?retryWrites=true&w=majority

# ================================
# SESIONES (REQUERIDO)
# ================================
# Secreto para firmar sesiones (genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_super_secret_session_key_here_change_this

# ================================
# EMAIL (REQUERIDO)
# ================================
# Servicio de email: 'gmail', 'smtp', o dejar vacío para Ethereal (testing)
EMAIL_SERVICE=gmail

# Para Gmail (recomendado para producción)
EMAIL_USER=tu-email@gmail.com
EMAIL_PASS=tu-app-password-de-gmail

# Remitente (FROM)
EMAIL_FROM=noreply@frescosenvivo.com

# ================================
# SMTP GENÉRICO (Alternativa a Gmail)
# ================================
# SMTP_HOST=smtp.tuservidor.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-usuario
# SMTP_PASS=tu-contraseña

# ================================
# OPCIONAL
# ================================
# JWT Secret (para futuras funcionalidades)
# JWT_SECRET=your_jwt_secret_key_here
