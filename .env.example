# Archivo de variables de entorno
# Copia este archivo como .env y configura tus valores

# Puerto del servidor
PORT=3000

# Entorno (development, production)
NODE_ENV=development

# Configuración de base de datos (opcional, para futuras versiones)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=livepescado
# DB_USER=postgres
# DB_PASSWORD=your_password

# Configuración de TURN servers (opcional, para mejorar conectividad WebRTC)
# TURN_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=username
# TURN_CREDENTIAL=password

# Claves de API (para futuras integraciones)
# STRIPE_SECRET_KEY=sk_test_...
# SENDGRID_API_KEY=SG...
